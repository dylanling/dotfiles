# Language runtime managers - sourced by .zshrc

# ==============================================
# asdf - universal version manager
# ==============================================
# Handles Node, Ruby, Python, and many other runtimes
# Install plugins with: asdf plugin add <name>
# Install versions with: asdf install <name> <version>
# Set global version: asdf global <name> <version>

# Homebrew installation (macOS)
if [ -f "/opt/homebrew/opt/asdf/libexec/asdf.sh" ]; then
  . /opt/homebrew/opt/asdf/libexec/asdf.sh
elif [ -f "/usr/local/opt/asdf/libexec/asdf.sh" ]; then
  # Intel Mac fallback
  . /usr/local/opt/asdf/libexec/asdf.sh
elif [ -f "$HOME/.asdf/asdf.sh" ]; then
  # Standalone installation fallback
  . "$HOME/.asdf/asdf.sh"
fi

# ==============================================
# fnm - fast Node manager
# ==============================================
# https://github.com/Schniz/fnm
if command -v fnm >/dev/null; then
  eval "$(fnm env --use-on-cd --corepack-enabled)"
fi

# ==============================================
# direnv - per-directory env vars
# ==============================================
# https://direnv.net/
if command -v direnv >/dev/null; then
  eval "$(direnv hook zsh)"
fi
