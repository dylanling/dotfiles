{
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(ls *)",
      "Bash(date *)",
      "Bash(cat *)",
      "Bash(mkdir *)",
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "Task"
    ],
    "deny": [
      "Bash(rm -rf *)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cd ~/notes && if [ -n \"$(git status --porcelain)\" ]; then echo '⚠️  You have uncommitted changes in ~/notes/. Run /commit or commit manually.'; fi"
          }
        ]
      }
    ]
  }
}
